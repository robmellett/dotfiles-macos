{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "theme": "light",
  "env": {
    "APP_ENV": "local"
  },
  "attribution": {},
  "permissions": {
    "allow": [
      "Bash(./vendor/bin/pest *)",
      "Bash(./vendor/bin/php-cs-fixer *)",
      "Bash(./vendor/bin/phpstan *)",
      "Bash(./vendor/bin/phpunit *)",
      "Bash(./vendor/bin/pint *)",
      "Bash(./vendor/bin/sail *)",
      "Bash(./vendor/bin/sail artisan *)",
      "Bash(./vendor/bin/sail exec *)",
      "Bash(./vendor/bin/sail test *)",
      "Bash(composer dump-autoload)",
      "Bash(composer install)",
      "Bash(composer require *)",
      "Bash(composer run-script *)",
      "Bash(composer update)",
      "Bash(docker compose *)",
      "Bash(find *)",
      "Bash(git branch *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git show *)",
      "Bash(git status)",
      "Bash(ls *)",
      "Bash(npm install)",
      "Bash(npm run *)",
      "Bash(php *)",
      "Bash(php artisan *)",
      "Bash(pnpm install)",
      "Read(./.php-cs-fixer.php)",
      "Read(./composer.json)",
      "Read(./composer.lock)",
      "Read(./package.json)",
      "Read(./phpstan.neon)",
      "Read(./phpunit.xml)",
      "Read(./pint.json)",
      "Read(./tailwind.config.js)",
      "Read(./vite.config.js)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Read(./storage/app/private/**)",
      "Bash(php artisan db:wipe)",
      "Bash(php artisan migrate:fresh)",
      "Bash(php artisan migrate:reset)",
      "Bash(rm -rf *)",
      "Bash(sudo *)",
      "Bash(chmod *)",
      "Bash(chown *)",
      "Bash(find * -delete *)",
      "Bash(find * -exec rm *)",
      "Bash(curl *)",
      "Bash(wget *)"
    ]
  },
  "extraKnownMarketplaces": {
    "phpstorm-marketplace": {
      "source": {
        "source": "github",
        "repo": "jetbrains/phpstorm-claude-marketplace"
      }
    }
  },
  "enabledPlugins": {
    "phpstorm-plugin@phpstorm-marketplace": true
  },
