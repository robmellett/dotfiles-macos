{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "APP_ENV": "local"
  },
  "attribution": {},
  "permissions": {
    "allow": [
      "Bash(composer install)",
      "Bash(composer update)",
      "Bash(composer require *)",
      "Bash(composer dump-autoload)",
      "Bash(composer run-script *)",
      "Bash(docker compose *)",
      "Bash(php artisan *)",
      "Bash(php *)",
      "Bash(./vendor/bin/pest *)",
      "Bash(./vendor/bin/phpunit *)",
      "Bash(./vendor/bin/phpstan *)",
      "Bash(./vendor/bin/pint *)",
      "Bash(./vendor/bin/php-cs-fixer *)",
      "Bash(./vendor/bin/sail *)",
      "Bash(./vendor/bin/sail artisan *)",
      "Bash(./vendor/bin/sail test *)",
      "Bash(./vendor/bin/sail exec *)",
      "Bash(npm install)",
      "Bash(npm run *)",
      "Bash(pnpm install)",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git show *)",
      "Bash(git branch *)",
      "Bash(ls *)",
      "Read(./composer.json)",
      "Read(./composer.lock)",
      "Read(./package.json)",
      "Read(./phpunit.xml)",
      "Read(./phpstan.neon)",
      "Read(./pint.json)",
      "Read(./.php-cs-fixer.php)",
      "Read(./vite.config.js)",
      "Read(./tailwind.config.js)",
      "Bash(find *)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Read(./storage/app/private/**)",
      "Bash(php artisan db:wipe)",
      "Bash(php artisan migrate:fresh)",
      "Bash(php artisan migrate:reset)",
      "Bash(rm -rf *)",
      "Bash(sudo *)",
      "Bash(chmod *)",
      "Bash(chown *)",
      "Bash(find * -delete *)",
      "Bash(find * -exec rm *)",
      "Bash(curl *)",
      "Bash(wget *)"
    ]
  },
  "extraKnownMarketplaces": {
    "phpstorm-marketplace": {
      "source": {
        "source": "github",
        "repo": "jetbrains/phpstorm-claude-marketplace"
      }
    }
  },
  "theme": "light",
  "enabledPlugins": {
    "phpstorm-plugin@phpstorm-marketplace": true
  }
}
